# -----------------------------------------------------------------------------
# Go
# -----------------------------------------------------------------------------
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# Test binaries
*.test

# Coverage
*.out
coverage/

# Dependencies
vendor/

# Workspace
go.work
go.work.sum

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
*.egg
build/
develop-eggs/
eggs/
.eggs/
wheels/

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing and coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# -----------------------------------------------------------------------------
# IDE and Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Secrets and credentials
# -----------------------------------------------------------------------------
# Environment files
.env
.env.*
!.env.example

# Private keys
*.pem
*.key
*.p12
*.pfx

# GitHub Apps configuration (contains private keys)
**/github-apps.json
**/github-apps-*.json
!**/github-apps.example.json

# -----------------------------------------------------------------------------
# Certificates
# -----------------------------------------------------------------------------
certs/*.crt
certs/*.pem
!certs/.gitkeep

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
.cache/
.config/

# -----------------------------------------------------------------------------
# Local development
# -----------------------------------------------------------------------------
# Application config (may contain secrets)
config.yaml
config.*.yaml
!config.example.yaml
!test/integration/config.yaml

# Docker
.docker/

# Docker volumes (dev environment)
local/.volumes/

# Air hot-reload temp files
.air/

# Local data
data/

# -----------------------------------------------------------------------------
# AI/Development tools
# -----------------------------------------------------------------------------
.claude/
.serena/
docs/superpowers/

# -----------------------------------------------------------------------------
# Other
# -----------------------------------------------------------------------------
.ignored
.config/
.cursor/
